# ==========================================================================
#  Configuration du serveur d'expédition Chronopost
#  Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
#  Le fichier .env ne doit JAMAIS être commité (voir .gitignore).
# ==========================================================================

# --- Mode ---
# true  = mode DÉMO : aucun appel réel, renvoie un faux n° de suivi (pour tester le flux)
# false = mode RÉEL : appelle vraiment l'API Chronopost (identifiants requis ci-dessous)
MOCK_MODE=true

# --- Identifiants API Chronopost (à demander à Chronopost / votre commercial) ---
# Ce sont les identifiants du WEB SERVICE d'expédition (ShippingService),
# différents de vos identifiants de connexion au site chronopost.fr.
CHRONO_ACCOUNT=            # numéro de compte / contrat (accountNumber)
CHRONO_PASSWORD=           # mot de passe API (password)
CHRONO_SUBACCOUNT=         # sous-compte (souvent vide)

# Point d'accès du web service (valeur par défaut = production Chronopost)
CHRONO_WS_URL=https://ws.chronopost.fr/shipping-cxf/ShippingServiceWS

# Format d'étiquette renvoyé : PDF | SPD (thermique 10x15) | PPR | ZPL
CHRONO_LABEL_FORMAT=PDF

# --- Compte administrateur (créé au tout premier démarrage) ---
# Sert à créer le 1er compte. À changer après la première connexion.
ADMIN_USER=admin
ADMIN_PASSWORD=alber2026

# --- Serveur ---
PORT=8787
# Origine autorisée à appeler ce serveur (CORS). Mettez l'URL où est hébergée
# la page de l'app, ou * pour tout autoriser (à éviter en production).
ALLOWED_ORIGIN=*
